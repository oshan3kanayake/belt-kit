rules_version = '2';

// ============================================================================
// BELT-KIT — Firestore Security Rules (free-tier, lean get() usage)
// ----------------------------------------------------------------------------
// role/branch come from /users/{uid}. To avoid exceeding Firestore's per-request
// get() limit, we read the user doc AT MOST ONCE per request via a single
// helper. Single-branch system, so no rule needs the doc's branchId.
//
// Permission model (per team decision): OWNER, FRONT DESK (advisor) and
// TECHNICIAN all have FULL access to the operational data (customers, vehicles,
// jobs, job lines, parts, services, suppliers, employees, etc.). Manager and
// accountant keep access too. Only genuinely dangerous actions (deleting staff,
// editing branches) stay owner/manager-only.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // Single source: the caller's /users doc data (one get per request path).
    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    // Role ALWAYS from the /users doc so seeded (claim) and created (no claim)
    // users take the IDENTICAL code path. Requires the /users doc to exist.
    function myRole() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? me().role : null;
    }

    // Any signed-in staff member.
    function isStaff() {
      return myRole() in ['owner', 'manager', 'advisor', 'technician', 'accountant'];
    }
    // The full-access team: owner, front desk, technician (+ manager kept).
    function isTeam() {
      return myRole() in ['owner', 'manager', 'advisor', 'technician'];
    }
    // Finance actions: invoices + payments (team + accountant).
    function isFinance() {
      return myRole() in ['owner', 'manager', 'advisor', 'technician', 'accountant'];
    }

    // ---- Users -----------------------------------------------------------
    match /users/{userId} {
      allow read: if signedIn();                 // any signed-in user may read
      allow create, update: if myRole() in ['owner', 'manager', 'advisor']
                    || (request.auth.uid == userId
                        && request.resource.data.role in ['owner', 'pending']);
      allow delete: if myRole() in ['owner', 'manager']; // deleting staff stays restricted
    }

    match /meta/{docId} {
      allow read: if signedIn();
      allow create: if signedIn() && docId == 'bootstrap'
                    && !exists(/databases/$(database)/documents/meta/bootstrap);
      allow update, delete: if false;
    }

    // ---- Branches (structural — keep restricted) -------------------------
    match /branches/{branchId} {
      allow read: if signedIn();
      allow write: if myRole() in ['owner', 'manager'];
    }

    // ---- Operational data: full access for the team ----------------------
    // Customers
    match /customers/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isTeam();
    }
    // Vehicles
    match /vehicles/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isTeam();
    }
    // Job Cards — technicians can now fully update (photos, status, etc.)
    match /jobCards/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isTeam();
    }
    // Job card lines (labour & parts)
    match /jobCardLines/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isTeam();
    }
    // Inventory
    match /parts/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isTeam();
    }
    match /stockMovements/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if false;   // history never edited
      allow delete: if isTeam();
    }
    // Services (service types offered by the garage)
    match /services/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isTeam();
    }

    // ---- Upcoming new collections (pre-added so no future block) ----------
    // Suppliers
    match /suppliers/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isTeam();
    }
    // Purchase orders (to suppliers)
    match /purchaseOrders/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isTeam();
    }
    // Employees
    match /employees/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isTeam();
    }
    // Employee pay records
    match /employeePayments/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isTeam();
    }
    // Attendance / leave
    match /attendance/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isTeam();
    }
    // In-app notifications
    match /notifications/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isStaff();
    }
    // Job photos (before/after) — if stored as their own collection
    match /jobPhotos/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isTeam();
    }

    // ---- Billing ---------------------------------------------------------
    match /invoices/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isFinance();
    }
    match /payments/{id} {
      allow read: if isStaff();
      allow create, delete: if isFinance();
      allow update: if false;
    }

    // ---- Audit log -------------------------------------------------------
    match /auditLog/{id} {
      allow read: if isFinance();
      allow create: if isFinance();
      allow update, delete: if false;
    }

    // Everything else is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
