# These are the environment variables the web app needs.
# In Vercel: Project Settings → Environment Variables → add each of these.
# Values come from Firebase console → Project settings → Your apps → web app config.
# They are PUBLIC (safe in the browser) — access is controlled by Firebase security rules.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=belt-kit.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=belt-kit
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=belt-kit.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=973733896346
NEXT_PUBLIC_FIREBASE_APP_ID=

# Leave both false for production (uses real cloud Firebase).
NEXT_PUBLIC_USE_EMULATOR=false
NEXT_PUBLIC_FUNCTIONS_EMULATOR=false
