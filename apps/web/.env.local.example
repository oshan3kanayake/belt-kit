# ============================================================================
# BELT-KIT Web — Firebase client config
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values from the Firebase
# console:  console.firebase.google.com/project/belt-kit/settings/general
#   → scroll to "Your apps" → if none, click the </> (Web) icon to register a
#     web app → copy the config values shown.
#
# These values are PUBLIC (safe in the browser). Access is protected by Auth +
# Firestore security rules, not by hiding these.
# ============================================================================

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=belt-kit.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=belt-kit
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=belt-kit.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=973733896346
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id-here

# Set to "true" to use the local emulator instead of real cloud.
# Leave "false" (or unset) to talk to the real belt-kit cloud project.
NEXT_PUBLIC_USE_EMULATOR=false
